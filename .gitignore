# Ignorar instaladores y archivos comprimidos pesados descargados
gimp_setup.exe
photogimp.zip

# Ignorar la carpeta del motor extraido de GIMP (pesa mas de 1GB y no debe ir a Git)
build/app/

# Carpetas temporales de compilacion o extraccion
temp_photogimp/
obj/
bin/

# Archivos de configuracion del sistema de desarrollo
.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# Archivos de registro y cache de ejecucion
*.log
*.tmp

# Credenciales locales
.env
**/.env

# Agente de WS y agentes locales
agente_de_ws/
.agents/
.claude/

# Politicas de privacidad (repositorio externo)
PrivacyPolicies/

# Archivos de empaquetado y firmas (contiene el PFX privado y MSIX pesado)
packaging/

# Documentacion de agentes y notas de trabajo
docs/

# Archivos de manifiesto y assets generados en build (excepto el ejecutable principal Lanzador.exe)
build/AppxManifest.xml
build/Assets/
